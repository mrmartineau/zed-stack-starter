# Postgres connection string (Neon / Supabase / any Postgres)
# Neon example: postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Better-auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3450

# Optional: comma-separated list of trusted origins
# BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3450

# Optional: set to "true" to disable signups (login only)
# BETTER_AUTH_DISABLE_SIGNUP=false
